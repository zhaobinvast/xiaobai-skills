# github-docker-build skill 配置示例
# 复制为 .env(或运行 install.sh 自动生成),填上你自己的值。

# 默认仓库,格式: OWNER/REPO(例如 zhaobinvast/my-project)
# 可通过 build.sh 的 -R 参数临时覆盖
GITHUB_REPO=owner/repo

# GitHub Token(可选)。如果本机已通过 gh auth login 认证,可留空。
# 如需使用 token: GitHub Settings → Developer settings → Personal access tokens → Fine-grained tokens
# 需要的权限: Actions(Read/Write) + Contents(Read)
GITHUB_TOKEN=