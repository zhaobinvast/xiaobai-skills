# grafana-loki skill 凭据配置示例
# 复制为 .env(或运行 install.sh 自动生成),填上你自己的值。
# 三个变量都必填,缺一不可。

# Grafana 实例地址,不要带末尾斜杠
GRAFANA_URL=https://grafana.tripo3d.ai

# Grafana Service Account Token,在 Grafana → Administration → Service accounts 新建
# 需要至少有对应 Loki 数据源的查询权限。形如 glsa_xxxxxxxx_yyyy
GRAFANA_TOKEN=glsa_replace_me

# Loki 数据源 UID,在 Grafana → Connections → Data sources 打开对应 Loki 源,
# 浏览器地址栏 /datasources/edit/<UID> 里那一段
LOKI_DS_UID=replace_me
